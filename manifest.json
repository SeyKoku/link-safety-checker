{
  "manifest_version": 3,
  "name": "Link Safety Checker",
  "version": "1.0.0",
  "description": "Flags suspicious links on the page and shows the current page's connection security in the toolbar.",
  "homepage_url": "https://github.com/SeyKoku/link-safety-checker",

  "permissions": ["webRequest", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Link Safety Checker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
